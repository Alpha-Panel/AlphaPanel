APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

THEME_PATH=Cryptograph

PANEL_ADMIN_NAME="Admin User"
PANEL_ADMIN_USERNAME=admin
PANEL_ADMIN_EMAIL=admin@example.com
PANEL_ADMIN_PASSWORD=change-me-now
PANEL_AUTO_APPLY_ON_DOMAIN_CHANGE=true

PANEL_CADDY_MAIN_CONFIG=/etc/frankenphp/Caddyfile
PANEL_CADDY_SITES_BASE=/etc/frankenphp/sites-enabled
PANEL_APACHE_SITES_BASE=/etc/apache2/sites-enabled
PANEL_PHP_FPM_POOL_BASE=/etc/php/8.5/fpm/pool.d
PANEL_LETSENCRYPT_BASE=/etc/letsencrypt/live

PANEL_DOCKER_TIMEOUT=15
PANEL_FRANKENPHP_CONTAINER=frankenphp
PANEL_PHP_CODE_SERVER_CONTAINER=php-code-server
PANEL_CADDY_ADMIN_URL=http://frankenphp:2019

PORTAINER_URL=https://portainer.example.com:8443
PORTAINER_API_KEY=
PORTAINER_ENDPOINT_ID=1
JENKINS_URL=https://jenkins.example.com
CROWDSEC_LAPI_URL=http://crowdsec:8080
CROWDSEC_DASHBOARD_API_KEY=
CROWDSEC_LAPI_TIMEOUT=5
COMPOSE_PROJECT_ROOT=/docker_compose_project_root
COMPOSE_PROJECT_ROOT_HOST=/root/docker/AlphaPanel-Docker
PORTAINER_CERTBOT_IMAGE=certbot/dns-cloudflare:v5.4.0

PANEL_LEGACY_DERIVE_UNIX_USER=false
PANEL_LEGACY_DEFAULT_UNIX_USER=www-data
PANEL_LEGACY_DEFAULT_UNIX_GROUP=www-data

REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Google Drive Backup
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKUP_RETENTION_DAYS=21

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Allowed WebSocket origins (comma-separated, * for all)
REVERB_ALLOWED_ORIGIN=*

# Cloudflare API (prefer API Token over Email+Key)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=
CLOUDFLARE_APIKEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ─── Update Agent ────────────────────────────────────────────
UPDATE_AGENT_URL=http://update-agent:8100
UPDATE_AGENT_SECRET=
PANEL_GITHUB_REPO=alphapanel/alphapanel-docker
UPDATE_AUTO_CHECK=true
