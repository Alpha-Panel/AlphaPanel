(common-headers) {
	tls /etc/letsencrypt/live/{$BASE_DOMAIN}/fullchain.pem /etc/letsencrypt/live/{$BASE_DOMAIN}/privkey.pem # certbot-managed
	encode zstd br gzip
	log {
		output file /var/log/caddy/server.log
		format console
	}
	header {
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		X-Content-Type-Options "nosniff"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		-x-powered-by
		X-Powered-By "Cryptograph"

		-via
		Via "Cryptograph"

		-server
		Server "Cryptograph"
	}
	# Statik dosyalar için uzun cache (1 yıl)
	@static {
		path *.css *.js *.mjs *.map
		path *.png *.jpg *.jpeg *.gif *.webp *.svg *.ico
		path *.woff *.woff2 *.ttf *.otf *.eot
		path *.mp4 *.webm *.avif
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# HTML için cache kapat / azalt (Laravel / PHP siteleri için güvenli)
	@html {
		header Content-Type *text/html*
	}
	header @html Cache-Control "no-cache, no-store, must-revalidate"
	header @html Pragma "no-cache"
	header @html Expires "0"
}

{
	email {env.ADMIN_EMAIL}
	#acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	frankenphp
	#debug
}

{$PANEL_DOMAIN}:443 {
	encode zstd br gzip
	root * /var/www/AlphaPanel/httpdocs/public

	# Reverb WebSocket (Laravel broadcasting)
	@websocket {
		path /app/*
	}
	reverse_proxy @websocket http://localhost:6001 {
		header_up Host {http.request.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection {http.request.header.Connection}

		transport http {
			versions 1.1
		}
	}

	# Terminal WebSocket proxy (php artisan terminal:serve --port=2999)
	@terminal_ws {
		path /terminal/ws
	}
	reverse_proxy @terminal_ws http://localhost:2999 {
		header_up Host {http.request.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection {http.request.header.Connection}

		transport http {
			versions 1.1
		}
	}
	# MySQL upgrade test phpMyAdmin (only responds when pma-upgrade-test container is running)
	@upgrade_test_pma {
		path /upgrade-test-pma /upgrade-test-pma/*
	}
	handle @upgrade_test_pma {
		uri strip_prefix /upgrade-test-pma
		reverse_proxy http://pma-upgrade-test:80
	}

	# Mailu direct-path handlers — serve absolute-path links inside admin/webmail/sso pages
	handle /static/* {
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
		}
	}
	handle /admin/* {
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}
	handle /sso/* {
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}
	handle /webmail/* {
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}

	# Mailu webmail via panel subpath — proxies to mailu-front's /webmail/
	handle /mail/webmail* {
		uri replace /mail/webmail /webmail
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}

	# Mailu admin via panel subpath — proxies to mailu-front's /admin/
	handle /mail/admin* {
		uri replace /mail/admin /admin
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}

	# Mailu SSO auth flow via panel subpath (auth for both webmail and admin)
	handle /mail/sso* {
		uri replace /mail/sso /sso
		reverse_proxy https://mailu-front:443 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {http.request.hostport}
			header_up X-Forwarded-Proto https
			header_down Location "^https?://[^/]+(/.+)" "$1"
			header_down Location "^(/.+)" "/mail$1"
			header_down Set-Cookie "; Domain=[^;]*" ""
		}
	}

	php_server {
		root /var/www/AlphaPanel/httpdocs/public
		worker {
			file frankenphp-worker.php
			num 3
		}
	}
	file_server
	import common-headers
}

{$CODE_SERVER_DOMAIN}:443 {
	import common-headers
	reverse_proxy http://php-code-server:8080 {
		# preserve host
		header_up Host {http.request.host}
		# forward original client IPs
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		# *** the two magic lines for WebSockets ***
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection {http.request.header.Connection}
		# *** forward the cookie so ServiceWorker fetches don't 401 ***
		header_up Cookie {http.request.header.Cookie}
		# if you have any Authorization headers (e.g. basic auth), forward them too
		header_up Authorization {http.request.header.Authorization}

		# force HTTP/1.1 upstream so websockets can Upgrade
		transport http {
			versions 1.1
		}
	}
}

{$PMA_DOMAIN}:443 {
	import common-headers
	reverse_proxy http://phpmyadmin:80 {
		# preserve host
		header_up Host {http.request.host}
		# forward original client IPs
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		# *** the two magic lines for WebSockets ***
		header_up Upgrade {http.request.header.Upgrade}
		header_up Connection {http.request.header.Connection}
		# *** forward the cookie so ServiceWorker fetches don't 401 ***
		header_up Cookie {http.request.header.Cookie}
		# if you have any Authorization headers (e.g. basic auth), forward them too
		header_up Authorization {http.request.header.Authorization}
	}
}

