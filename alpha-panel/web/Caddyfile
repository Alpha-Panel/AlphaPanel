{$N8N_DOMAIN}:443 {
	import common-headers
	reverse_proxy http://n8n:8443 {
		# Host'u port'suz gönder (Caddy placeholder'ı host-only)
		header_up Host {http.request.host}
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Port 8443

		# 🔥 ASIL OLAY: Origin / Referer port'suz olsun
		header_up Origin {http.request.scheme}://{http.request.host}
		header_up Referer {http.request.scheme}://{http.request.host}{http.request.uri}

		transport http {
			versions 1.1
		}
	}
}

{$PORTAINER_DOMAIN}:443 {
	import common-headers

	reverse_proxy http://portainer:9000 {
		# Host'u port'suz gönder (Caddy placeholder'ı host-only)
		header_up Host {http.request.host}
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Port 443

		# 🔥 ASIL OLAY: Origin / Referer port'suz olsun
		header_up Origin {http.request.scheme}://{http.request.host}
		header_up Referer {http.request.scheme}://{http.request.host}{http.request.uri}

		transport http {
			versions 1.1
		}
	}
}
