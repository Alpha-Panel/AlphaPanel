# ─── Cloudflare ───────────────────────────────────────────────
CF_API_TOKEN=your_cloudflare_api_token

# ─── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

# ─── MySQL ────────────────────────────────────────────────────
MYSQL_VERSION=9.3.0
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=alpha_panel

# ─── FTP (ProFTPD MySQL Auth) ────────────────────────────────
FTP_MYSQL_PASSWORD=change_me

# ─── Meilisearch ──────────────────────────────────────────────
MEILISEARCH_MASTER_KEY=change_me_32chars_min
ALPHA_PANEL_MEILISEARCH_MASTER_KEY=change_me_32chars_min

# ─── PostgreSQL (N8N) ─────────────────────────────────────────
POSTGRESQL_USER=admin
POSTGRESQL_PASSWORD=change_me

# ─── Network ──────────────────────────────────────────────────
PRIVATE_NETWORK_IP=127.0.0.1
PUBLIC_NETWORK_IP=0.0.0.0

# ─── Domains ──────────────────────────────────────────────────
# BASE_DOMAIN is used for the wildcard SSL certificate (*.BASE_DOMAIN)
BASE_DOMAIN=example.com
PANEL_DOMAIN=server.example.com
PMA_DOMAIN=pma.example.com
CODE_SERVER_DOMAIN=file.example.com
VAULTWARDEN_DOMAIN=password.example.com
N8N_DOMAIN=n8n.example.com
PORTAINER_DOMAIN=portainer.example.com
JENKINS_DOMAIN=jenkins.example.com
JENKINS_ADMIN_IPS=

# ─── Vaultwarden ──────────────────────────────────────────────
VAULTWARDEN_DB_HOST=mysql
VAULTWARDEN_DB_NAME=bitwarden
VAULTWARDEN_DB_USER=bitwarden
VAULTWARDEN_DB_PASSWORD=change_me

# ─── Code Server (File Manager) ───────────────────────────────
CODE_SERVER_PASSWORD=change_me
CODE_SERVER_SUDO_PASSWORD=change_me
CODE_SERVER_PWA_APP_NAME="AlphaPanel Code Server"

# ─── N8N ──────────────────────────────────────────────────────
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=
N8N_SMTP_SSL=false
N8N_ENCRYPTION_KEY=change_me_32chars_min

# ─── phpMyAdmin ───────────────────────────────────────────────
PMA_BLOWFISH_SECRET=change_me_32chars
PANEL_DB_NAME=AlphaPanel
PANEL_DB_USER=alphapanel
PANEL_DB_PASS=change_me
PMA_URL=https://pma.example.com:8443/index.php?server=2
PANEL_APP_KEY=

# ─── Update Agent ────────────────────────────────────────────
UPDATE_AGENT_SECRET=change_me
PANEL_GITHUB_REPO=alphapanel/alphapanel-docker

# ─── CrowdSec / Coraza ────────────────────────────────────────
# En az 32 karakter rastgele key kullanın.
CROWDSEC_FIREWALL_BOUNCER_KEY=change_me_very_long_random_string
CROWDSEC_DASHBOARD_API_KEY=change_me_second_very_long_random_string
CROWDSEC_LAPI_URL=http://crowdsec:8080

# ─── DNS Server (PowerDNS) ────────────────────────────────────
DNS_NS1=ns1.example.com
DNS_NS2=ns2.example.com
DNS_SOA_ADMIN=admin.example.com

# ─── Resource Limits (Optional) ─────────────────────────────
# Aktif etmek icin asagidaki satirin basindaki # isareti kaldirin:
# COMPOSE_FILE=docker-compose.yaml:docker-compose.resources.yaml
#
# Varsayilan degerler 6 CPU / 12 GB RAM icin optimize edilmistir.
# Ozellestirilmis degerler icin asagidaki degiskenleri ayarlayin:
# FRANKENPHP_CPU_LIMIT=2.0

# ─── Resource Limits (optional) ──────────────────────────────
# FRANKENPHP_MEM_LIMIT=3G
# ALPHA_PANEL_CPU_LIMIT=1.5
# ALPHA_PANEL_MEM_LIMIT=2G
# CODE_SERVER_CPU_LIMIT=1.5
# CODE_SERVER_MEM_LIMIT=2G
# MYSQL_CPU_LIMIT=1.5
# MYSQL_MEM_LIMIT=3G
# REDIS_CPU_LIMIT=0.5
# REDIS_MEM_LIMIT=512M
