# =============================================================================
# AlphaPanel-Docker — .gitignore
# =============================================================================

# =============================================================================
# SECRETS & CREDENTIALS
# =============================================================================

# Root environment file (contains API tokens, DB passwords, etc.)
.env
# Keep the template
!.env.example

# Cloudflare API token for certbot DNS-01 challenge
secrets/

# FTP user passwords
ftp-config/users.env
!ftp-config/users.env.example

# SSH keys for terminal access (private key)
alpha-panel/web/ssh-keys/

# Laravel application environment
alpha-panel/web/httpdocs/.env
!alpha-panel/web/httpdocs/.env.example


# =============================================================================
# SSL / TLS — PRIVATE KEYS (NEVER commit)
# =============================================================================

# Let's Encrypt certificates (real private keys live here)
letsencrypt/

# Self-signed / dev certs
alpha-panel/web/ssl/
apache/certs/
apache/sites-enabled

# Caddy TLS state (ACME account keys, cert cache)
frankenphp/caddy_data/
frankenphp/sites-enabled
alpha-panel/web/caddy_data/
frankenphp/supervisor
frankenphp/waf


# =============================================================================
# DATABASE DATA
# =============================================================================

mysql/data/
postgres/
redis/


# =============================================================================
# SEARCH INDEX DATA
# =============================================================================

meilisearch/data/
meilisearch/tmp/
alpha-panel/meilisearch/data/
alpha-panel/meilisearch/tmp/


# =============================================================================
# PHP-FPM RUNTIME & GENERATED POOL CONFIGS
# =============================================================================

# PHP-FPM socket / PID files (created at runtime)
php-code-server/run/

# Domain-specific FPM pool configs generated by panel:apply — keep only the
# default www.conf which ships with the repo.
php-code-server/*/fpm.d/*.conf
!php-code-server/*/fpm.d/www.conf

# PHP-FPM supervisor configs — runtime state managed by panel (enable=create, disable=delete).
# Stubs tracked as php-fpm-*.conf.stub; actual .conf files are gitignored.
php-code-server/supervisor.d/php-fpm-*.conf

# PHP ini files — user-customizable at runtime via panel.
# Stubs tracked as php.ini.stub; actual php.ini files are gitignored.
php-code-server/*/php.ini


# =============================================================================
# SERVICE RUNTIME DATA
# =============================================================================

# Portainer (contains hashed admin password, endpoint config)
/portainer/

# Vaultwarden / Bitwarden (encrypted password vault)
vaultwarden/data/

# N8N (workflow credentials, encryption keys at rest)
n8n/data/
n8n/files/

# Code Server user data
code-server/data/

# FrankenPHP root home (claude/codex credentials, bash history)
frankenphp/home/

# Jenkins (build history, credentials, secret keys)
jenkins/data/
jenkins/keys


# =============================================================================
# HOSTED SITE FILES & CACHES
# =============================================================================

# Customer / hosted domain files
vhosts/

# Git deploy cache (intermediate artefacts)
deploy_cache/

# =============================================================================
# BACKUP — CREDENTIALS & LOCAL CONFIG
# =============================================================================
# scripts/backup/ dizini backup scriptlerini içerir; yedek dosyalar burada
# tutulmaz. Aşağıdaki dosyalar kimlik bilgisi veya yerel konfigürasyon
# içerdiğinden asla commit'lenmez — kurulum sonrası manuel oluşturulmalıdır.

# Sunucu / DB bağlantı bilgileri (manuel oluşturulur)
scripts/backup/server_info.sh
!scripts/backup/server_info.sh.example

# Google Drive backup ayarları — Drive folder ID ve e-posta (manuel oluşturulur)
scripts/backup/settings.json
!scripts/backup/settings.json.example

# Google OAuth2 kimlik bilgileri (Google Cloud Console'dan indirilir)
scripts/backup/credentials.json

# Google Drive API service account anahtarı (Google Cloud Console'dan indirilir)
scripts/backup/service_account.json

# OAuth token — drivebackup.py ilk çalışmada otomatik oluşturur
scripts/backup/token.json

# =============================================================================
# LOG FILES
# =============================================================================

frankenphp/logs/
frankenphp/coraza-logs/*
!frankenphp/coraza-logs/.gitkeep
frankenphp/waf/generated/*
!frankenphp/waf/generated/global.conf
!frankenphp/waf/generated/domains/
!frankenphp/waf/generated/domains/.gitkeep
!frankenphp/waf/generated/domains/000-default.conf
alpha-panel/web/logs/
crowdsec/data/*
!crowdsec/data/.gitkeep
*.log


# =============================================================================
# LOCAL SERVICE OVERRIDES (user-specific, not for sharing)
# =============================================================================

includeservices/*.yaml
includeservices/*.yml
# Keep shipped examples and the README
!external-services/empty.yaml
!includeservices/*.example.yaml
!includeservices/*.example.yml
!external-services/README.md


# =============================================================================
# LARAVEL BUILD ARTEFACTS
# =============================================================================

alpha-panel/web/httpdocs/vendor/
alpha-panel/web/httpdocs/node_modules/
alpha-panel/web/httpdocs/public/build/
alpha-panel/web/httpdocs/public/hot

# Laravel framework cache (regenerated at runtime)
alpha-panel/web/httpdocs/storage/framework/cache/
alpha-panel/web/httpdocs/storage/framework/sessions/
alpha-panel/web/httpdocs/storage/framework/views/
alpha-panel/web/httpdocs/storage/logs/

# Bootstrap cache (regenerated by artisan)
alpha-panel/web/httpdocs/bootstrap/cache/*.php
!alpha-panel/web/httpdocs/bootstrap/cache/.gitignore


# =============================================================================
# OS / EDITOR NOISE
# =============================================================================

.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.ai
.claude
.codex
.gemini
.junie
.mcp.json
boost.json
tasks

__pycache__

# =============================================================================
# INSTALLER (Flask web installer)
# =============================================================================
.installer-venv/
.installer_state.json

docs
AlphaPanel-API.postman_collection.json
API-DOCUMENTATION.md